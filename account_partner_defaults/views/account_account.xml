<record id="view_account_account_kanban_zinapsia" model="ir.ui.view">
    <field name="name">account.account.form.zinapsia</field>
    <field name="model">account.account</field>
    <field name="inherit_id" ref="account.view_account_form"/>
    <field name="arch" type="xml">
        <xpath expr="//notebook" position="inside">
            <page string="Zinapsia: Contactos Asociados" name="zinapsia_partners">
                <group string="Resumen de Contactos">
                    <field name="expense_partner_names" string="Nombres de Contactos (Gastos)"/>
                    <field name="income_partner_names" string="Nombres de Contactos (Ingresos)"/>
                </group>
            </page>
        </xpath>
    </field>
</record>