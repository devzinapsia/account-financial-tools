<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_account_list_partner_info_zinapsia" model="ir.ui.view">
        <field name="name">account.account.tree.partner.info.zinapsia</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_list" />
        <field name="arch" type="xml">
            <field name="account_type" position="after">
                <field name="expense_partner_names" string="Expense Partners" optional="hide" readonly="1"/>
                <field name="income_partner_names" string="Income Partners" optional="hide" readonly="1"/>
            </field>
        </field>
    </record>

    <record id="view_account_form_partner_info_zinapsia" model="ir.ui.view">
        <field name="name">account.account.form.partner.info.zinapsia</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form" />
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Zinapsia: Associated Partners" groups="account.group_account_readonly">
                    <group>
                        <group string="Partner Summary">
                            <field name="expense_partner_names" readonly="1"/>
                            <field name="income_partner_names" readonly="1"/>
                        </group>
                    </group>
                    <separator string="Technical Details"/>
                    <group>
                        <group string="Expense Account Users">
                            <field name="expense_partner_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                        </group>
                        <group string="Income Account Users">
                            <field name="income_partner_ids" nolabel="1" widget="many2many_tags" readonly="1"/>
                        </group>
                    </group>
                </page>
            </notebook>
        </field>
    </record>
</odoo>