<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_projected_flows" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.projected.flows</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='settings']" position="inside">
                <div class="app_settings_block" data-key="projected_flows_settings">
                    <h2>Flujos Proyectados</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6">
                            <label for="projected_flow_initial_balance_ids"/>
                            <field name="projected_flow_initial_balance_ids"
                                   widget="many2many_tags"
                                   options="{'no_create': True, 'no_open': True}"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>